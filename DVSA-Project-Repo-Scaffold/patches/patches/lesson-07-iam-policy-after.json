{
  "note": "After remediation: least-privilege policy for DVSA-SEND-RECEIPT-EMAIL.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOrdersTableOnly",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:836739852202:table/DVSA-ORDERS-DB"
      ]
    },
    {
      "Sid": "SendReceiptEmailOnly",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*"
    }
  ]
}
